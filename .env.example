# Steam Web API key - https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Session encryption (32+ random characters)
SESSION_SECRET=

# Public URL of your site (required in production for share links & OG previews)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Search Console - meta tag verification code (optional)
GOOGLE_SITE_VERIFICATION=

# Persistent leaderboard storage (Vercel KV / Upstash Redis REST)
# In Vercel: Storage -> KV -> Connect Project, then redeploy.
KV_REST_API_URL=
KV_REST_API_TOKEN=
